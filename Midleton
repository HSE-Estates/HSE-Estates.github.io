<!DOCTYPE html>
<html lang="en-IE">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Midleton Live Water Level | Infrastructure Intelligence</title>
    
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
    
    <!-- Leaflet Map CSS & JS -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap');
        
        body { 
            font-family: 'Inter', system-ui, -apple-system, sans-serif; 
            -webkit-font-smoothing: antialiased;
            background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%);
            color: #1e293b;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }
        
        :root {
            --hse-primary: #006858;
            --hse-secondary: #00bfa5;
            --hse-dark: #004d42;
        }

        .hse-gradient {
            background: linear-gradient(135deg, #004d42 0%, #006858 50%, #00917a 100%);
            position: relative;
            overflow: hidden;
        }

        .hse-gradient::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
            opacity: 0.4;
        }

        .app-card {
            background: linear-gradient(to bottom, #ffffff, #fefefe);
            border: 1px solid rgba(226, 232, 240, 0.8);
            box-shadow: 0 25px 50px -12px rgba(0, 104, 88, 0.15), 0 10px 20px -8px rgba(0, 0, 0, 0.1);
        }

        .pulse-glow {
            animation: pulseGlow 2s ease-in-out infinite;
        }

        @keyframes pulseGlow {
            0%, 100% { box-shadow: 0 0 5px rgba(16, 185, 129, 0.5); }
            50% { box-shadow: 0 0 20px rgba(16, 185, 129, 0.8); }
        }

        .pulse-glow-error {
            animation: pulseGlowError 2s ease-in-out infinite;
        }

        @keyframes pulseGlowError {
            0%, 100% { box-shadow: 0 0 5px rgba(239, 68, 68, 0.5); }
            50% { box-shadow: 0 0 20px rgba(239, 68, 68, 0.8); }
        }

        /* Progress Bar Animation */
        .progress-bar {
            transition: width 1s cubic-bezier(0.4, 0, 0.2, 1);
        }

        /* Ensure map renders properly and stays behind custom UI elements */
        #map { z-index: 1; }
        .leaflet-control-container { z-index: 2; }
        
        /* Custom Scrollbar */
        ::-webkit-scrollbar { width: 10px; }
        ::-webkit-scrollbar-track { background: #f1f5f9; }
        ::-webkit-scrollbar-thumb { 
            background: linear-gradient(135deg, #cbd5e1, #94a3b8); 
            border-radius: 10px; 
        }
        ::-webkit-scrollbar-thumb:hover { background: linear-gradient(135deg, #94a3b8, #64748b); }
    </style>
</head>
<body>

    <!-- Header Section -->
    <header class="hse-gradient text-white pt-8 pb-20 px-4 md:px-8 relative shadow-lg">
        <div class="max-w-5xl mx-auto relative z-10">
            
            <div class="flex justify-between items-center mb-6">
                <div class="flex items-center gap-4">
                    <div class="bg-white/10 backdrop-blur-md p-3 rounded-2xl border border-white/20 shadow-lg">
                        <i data-lucide="waves" class="w-8 h-8 text-emerald-100"></i>
                    </div>
                    <div>
                        <h1 class="text-xl md:text-2xl font-black tracking-tight">Midleton Town Park</h1>
                        <p class="text-[10px] md:text-xs text-emerald-200 font-bold uppercase tracking-widest">Live Water Level Monitoring</p>
                    </div>
                </div>
                
                <div class="text-right hidden sm:block">
                    <p class="text-[10px] font-black text-emerald-200 uppercase tracking-widest bg-black/20 px-3 py-1.5 rounded-lg inline-block">Station 19117</p>
                </div>
            </div>

        </div>
    </header>

    <!-- Main Content Area -->
    <main class="max-w-5xl mx-auto px-4 md:px-8 -mt-12 flex-1 w-full relative z-10 pb-12">
        
        <!-- App Card Wrapper -->
        <div class="app-card rounded-3xl overflow-hidden flex flex-col relative z-20">
            
            <!-- Map Container -->
            <div class="relative w-full h-48 md:h-[300px] bg-slate-100 border-b border-slate-200">
                <div id="map" class="absolute inset-0"></div>
                
                <!-- Floating Controls over map -->
                <div class="absolute top-4 right-4 z-[400] flex flex-col gap-2">
                    <button id="refresh-btn" class="bg-white/95 backdrop-blur-sm p-3 rounded-2xl shadow-lg text-slate-700 hover:text-[#006858] active:scale-95 transition-all border border-slate-200/50" aria-label="Refresh Data">
                        <i data-lucide="refresh-cw" id="refresh-icon" class="w-5 h-5"></i>
                    </button>
                    <!-- Mobile Station ID -->
                    <div class="sm:hidden bg-white/95 backdrop-blur-sm px-3 py-2 rounded-xl shadow-lg border border-slate-200/50 text-center">
                        <span class="text-[9px] font-black text-slate-500 uppercase tracking-widest block leading-tight">STN</span>
                        <span class="text-xs font-bold text-slate-800">19117</span>
                    </div>
                </div>
            </div>

            <!-- Live Data Dashboard -->
            <div class="bg-white p-6 md:p-8">
                
                <!-- Status Header -->
                <div class="flex justify-between items-center mb-8 pb-4 border-b border-slate-100">
                    <div class="flex items-center gap-3">
                        <div id="status-dot" class="w-3 h-3 rounded-full bg-emerald-500 pulse-glow"></div>
                        <span class="text-[10px] font-black text-slate-500 uppercase tracking-widest">Live System Feed</span>
                    </div>
                    <div class="flex items-center gap-2 text-xs font-semibold text-slate-600 bg-slate-50 px-3 py-1.5 rounded-lg border border-slate-100">
                        <i data-lucide="clock" class="w-3.5 h-3.5 text-slate-400"></i>
                        <span id="live-time">Connecting...</span>
                    </div>
                </div>

                <!-- Metrics & Benchmark Grid -->
                <div class="grid grid-cols-1 md:grid-cols-12 gap-6 md:gap-8">
                    
                    <!-- Primary Metric: OD Malin -->
                    <div class="md:col-span-5 bg-gradient-to-br from-[#f8fafc] to-[#f1f5f9] rounded-2xl p-6 border border-slate-200/60 relative overflow-hidden group shadow-sm flex flex-col justify-center">
                        <div class="absolute -right-6 -bottom-6 opacity-5 group-hover:opacity-10 transition-opacity">
                            <i data-lucide="arrow-up-right" class="w-48 h-48"></i>
                        </div>
                        
                        <div class="flex items-start justify-between mb-2">
                            <h2 class="text-[11px] font-black uppercase tracking-widest text-[#006858] bg-[#006858]/10 px-3 py-1 rounded-md">Live OD Malin</h2>
                            <div class="flex flex-col items-end">
                                <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Staff Gauge</span>
                                <span id="live-gauge" class="text-sm font-black text-slate-600">--.---m</span>
                            </div>
                        </div>
                        
                        <div class="mt-2 flex items-baseline gap-1">
                            <span id="live-od" class="text-5xl md:text-6xl font-black text-slate-900 tracking-tight">--.---</span>
                            <span class="text-2xl font-bold text-slate-400">m</span>
                        </div>
                    </div>

                    <!-- Benchmark / Risk Gauge -->
                    <div class="md:col-span-7 bg-white rounded-2xl p-6 border border-slate-200/60 shadow-sm flex flex-col justify-between">
                        
                        <div class="flex justify-between items-start mb-4">
                            <div>
                                <h2 class="text-[11px] font-black uppercase tracking-widest text-rose-600 bg-rose-50 px-3 py-1 rounded-md inline-block mb-2">Flood Benchmark</h2>
                                <h3 class="text-xl font-black text-slate-800">3.265m <span class="text-sm font-bold text-slate-400">OD</span></h3>
                                <p class="text-xs text-slate-500 font-medium mt-1 flex items-center gap-1">
                                    <i data-lucide="calendar" class="w-3 h-3"></i> Recorded: 23 Feb 2025
                                </p>
                            </div>
                            
                            <div class="text-right">
                                <span id="risk-percentage" class="text-3xl font-black text-slate-800">--%</span>
                                <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mt-1">of Record High</p>
                            </div>
                        </div>

                        <!-- Progress Bar Visual -->
                        <div class="w-full mt-4">
                            <div class="flex justify-between text-[10px] font-bold text-slate-400 mb-1 px-1">
                                <span>0.0m (Dry)</span>
                                <span>Record Flood (3.265m)</span>
                            </div>
                            <div class="h-4 w-full bg-slate-100 rounded-full overflow-hidden border border-slate-200/50 relative">
                                <!-- Warning Threshold Markers (Optional visual guides) -->
                                <div class="absolute top-0 bottom-0 w-px bg-yellow-400/50 left-[50%] z-10"></div>
                                <div class="absolute top-0 bottom-0 w-px bg-rose-400/50 left-[80%] z-10"></div>
                                
                                <!-- Dynamic Fill -->
                                <div id="progress-fill" class="h-full progress-bar bg-gradient-to-r from-emerald-400 to-emerald-500 relative z-0" style="width: 0%;"></div>
                            </div>
                            <p id="risk-status" class="text-xs font-bold text-emerald-600 mt-3 text-center">Fetching status...</p>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </main>

    <script>
        // Initialise Icons safely
        if (typeof lucide !== 'undefined') {
            lucide.createIcons();
        }

        // --- MAP CONFIGURATION ---
        const lat = 51.9162;
        const lng = -8.1720;
        
        // Initialise Leaflet Map
        const map = L.map('map', {
            zoomControl: false,
            scrollWheelZoom: false // Disable scroll zoom to prevent getting trapped while scrolling page
        }).setView([lat, lng], 15);

        // Add Zoom control manually to bottom right
        L.control.zoom({ position: 'bottomright' }).addTo(map);

        // Add Map Tiles
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            maxZoom: 19,
            attribution: '&copy; OpenStreetMap'
        }).addTo(map);

        // Custom HSE Marker Style
        const hseMarkerHtml = `
            <div style="background-color: #006858; width: 24px; height: 24px; border-radius: 50%; border: 3px solid white; box-shadow: 0 4px 6px rgba(0,0,0,0.3); display: flex; align-items: center; justify-content: center;">
                <div style="background-color: white; width: 6px; height: 6px; border-radius: 50%;"></div>
            </div>
        `;
        const customIcon = L.divIcon({
            html: hseMarkerHtml,
            className: 'custom-leaflet-marker',
            iconSize: [24, 24],
            iconAnchor: [12, 12],
            popupAnchor: [0, -12]
        });

        // Add Marker
        const marker = L.marker([lat, lng], { icon: customIcon }).addTo(map);
        marker.bindPopup("<div class='font-sans p-1'><b class='text-[#006858] text-sm block mb-1'>Town Park Gauge</b><span class='text-xs text-slate-600'>Fetching live data...</span></div>");

        // --- CONSTANTS & DOM ELEMENTS ---
        const OFFSET = 1.876;
        const RECORD_HIGH_OD = 3.265; // Highest recorded flood
        
        const liveOdEl = document.getElementById('live-od');
        const liveGaugeEl = document.getElementById('live-gauge');
        const liveTimeEl = document.getElementById('live-time');
        const statusDot = document.getElementById('status-dot');
        const refreshIcon = document.getElementById('refresh-icon');
        
        const riskPercentageEl = document.getElementById('risk-percentage');
        const progressFillEl = document.getElementById('progress-fill');
        const riskStatusEl = document.getElementById('risk-status');

        // --- LOGIC ---
        function updateRiskGauge(currentOd) {
            // Calculate percentage of record high
            const safeOd = Math.max(0, currentOd); 
            let percentage = (safeOd / RECORD_HIGH_OD) * 100;
            
            // Cap visual bar at 100% (though text can show >100%)
            const visualPercentage = Math.min(percentage, 100);
            
            // Update UI
            riskPercentageEl.innerText = `${percentage.toFixed(1)}%`;
            progressFillEl.style.width = `${visualPercentage}%`;

            // Change colours and status text based on severity
            progressFillEl.className = "h-full progress-bar relative z-0 ";
            
            if (percentage < 50) {
                progressFillEl.className += "bg-gradient-to-r from-emerald-400 to-emerald-500";
                riskStatusEl.innerText = "Normal Levels - Safe";
                riskStatusEl.className = "text-xs font-bold text-emerald-600 mt-3 text-center";
            } else if (percentage < 80) {
                progressFillEl.className += "bg-gradient-to-r from-yellow-400 to-amber-500";
                riskStatusEl.innerText = "Elevated Levels - Monitor Closely";
                riskStatusEl.className = "text-xs font-bold text-amber-600 mt-3 text-center";
            } else if (percentage < 100) {
                progressFillEl.className += "bg-gradient-to-r from-orange-500 to-rose-500";
                riskStatusEl.innerText = "High Risk - Approaching Record Levels";
                riskStatusEl.className = "text-xs font-bold text-rose-600 mt-3 text-center";
            } else {
                progressFillEl.className += "bg-gradient-to-r from-rose-600 to-red-700 animate-pulse";
                riskStatusEl.innerText = "CRITICAL: Exceeding Record Flood Level!";
                riskStatusEl.className = "text-xs font-black text-red-700 mt-3 text-center bg-red-50 py-1 rounded-md";
            }
        }

        async function fetchLiveData() {
            try {
                // UI Loading State
                refreshIcon.classList.add('animate-spin');
                liveTimeEl.innerText = "Updating...";
                statusDot.className = "w-3 h-3 rounded-full bg-amber-400";

                let csvText = "";
                const opwUrl = 'https://waterlevel.ie/data/day/19117_0001.csv';
                
                // Array of URLs to try in a "waterfall" sequence
                const fetchUrls = [
                    opwUrl + '?t=' + new Date().getTime(), // 1. Direct fetch (best if hosted on a real server later)
                    `https://api.codetabs.com/v1/proxy?quest=${encodeURIComponent(opwUrl)}`, // 2. CodeTabs proxy
                    `https://thingproxy.freeboard.io/fetch/${opwUrl}`, // 3. ThingProxy
                    `https://api.allorigins.win/raw?url=${encodeURIComponent(opwUrl)}` // 4. AllOrigins proxy
                ];

                let fetchSuccess = false;

                // Loop through our proxies until one successfully returns the data
                for (const url of fetchUrls) {
                    try {
                        const response = await fetch(url);
                        if (response.ok) {
                            const text = await response.text();
                            
                            // Basic validation: Check if it actually looks like CSV data
                            // (Prevents proxy HTML error pages from crashing the app)
                            if (text && text.includes(',')) {
                                csvText = text;
                                fetchSuccess = true;
                                break; // Stop trying URLs once we have our data!
                            }
                        }
                    } catch (err) {
                        // Silently catch and try the next URL in the array
                        console.warn(`Fetch blocked for ${url}, falling back...`);
                    }
                }
                
                if (!fetchSuccess) {
                    throw new Error("All fetching methods were blocked by CORS or network issues.");
                }
                
                // Parse the CSV Text (format: datetime,value)
                const lines = csvText.trim().split('\n');
                if (lines.length > 1) { // Make sure there's data beyond a potential header
                    const lastLine = lines[lines.length - 1];
                    const parts = lastLine.split(',');
                    
                    if (parts.length >= 2) {
                        const datetimeStr = parts[0]; 
                        const gaugeValue = parseFloat(parts[1]);
                        const odValue = gaugeValue + OFFSET;
                        
                        // Parse time. OPW returns UTC, so append 'Z' to format to Irish Time
                        const dt = new Date(datetimeStr.replace(' ', 'T') + 'Z');
                        const timeString = dt.toLocaleTimeString('en-IE', { hour: '2-digit', minute: '2-digit' });
                        const dateString = dt.toLocaleDateString('en-IE', { day: 'numeric', month: 'short' });

                        // Update DOM
                        liveGaugeEl.innerText = gaugeValue.toFixed(3) + "m";
                        liveOdEl.innerText = odValue.toFixed(3);
                        liveTimeEl.innerText = `${dateString}, ${timeString}`;
                        
                        // Update Risk Gauge
                        updateRiskGauge(odValue);

                        // Update Map Marker
                        marker.getPopup().setContent(`
                            <div class='font-sans p-1 text-center'>
                                <b class='text-[#006858] text-sm block mb-1'>Town Park Gauge</b>
                                <span class='text-xs text-slate-600'>OD Level: <b class='text-slate-900'>${odValue.toFixed(3)}m</b></span>
                            </div>
                        `);
                        
                        // Success Status
                        statusDot.className = "w-3 h-3 rounded-full bg-emerald-500 pulse-glow";
                    }
                } else {
                    throw new Error("Invalid CSV data format received.");
                }
            } catch (error) {
                console.error("Failed to fetch live data:", error);
                liveTimeEl.innerText = "Connection Failed";
                liveOdEl.innerText = "Err";
                liveGaugeEl.innerText = "Err";
                riskPercentageEl.innerText = "--%";
                riskStatusEl.innerText = "System offline. Unable to pull external data.";
                riskStatusEl.className = "text-xs font-bold text-slate-500 mt-3 text-center";
                progressFillEl.style.width = "0%";
                
                // Error Status
                statusDot.className = "w-3 h-3 rounded-full bg-red-500 pulse-glow-error";
            } finally {
                // Stop spinning icon
                setTimeout(() => refreshIcon.classList.remove('animate-spin'), 500);
            }
        }

        // Fetch on load
        fetchLiveData();

        // Fetch on manual refresh button click
        document.getElementById('refresh-btn').addEventListener('click', fetchLiveData);

        // Auto-refresh every 5 minutes (300,000 milliseconds)
        setInterval(fetchLiveData, 300000);

    </script>
</body>
</html>
